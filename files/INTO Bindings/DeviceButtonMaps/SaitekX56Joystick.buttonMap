	<Joy_YAxis>Stick Y</Joy_YAxis>
	<Joy_RZAxis>Stick Twist</Joy_RZAxis>
	<Joy_RXAxis>Joy Ministick X</Joy_RXAxis>
	<Joy_RYAxis>Joy Ministick Y</Joy_RYAxis>

	<!-- Silver POV Hat (POV1) -->
	<Joy_POV1Up>POV Up</Joy_POV1Up>
	<Joy_POV1Right>POV Right</Joy_POV1Right>
	<Joy_POV1Down>POV Down</Joy_POV1Down>
	<Joy_POV1Left>POV Left</Joy_POV1Left>
</Root>
